//_________________________________________________________________________________


void GNetClientFDT::ReadBuffer() {
	// Read a buffer
	struct timeval mt_reference;
	struct timeval mt_Timeout;
	struct timezone tz;
	Int_t time_out = 10;
	gettimeofday(&mt_Timeout, &tz);
	gettimeofday(&mt_reference, &tz);
	fStatus = ACQ_OK;
	while (true) {

		GetBuffer(false);
		gettimeofday(&mt_Timeout, &tz);

		if (((mt_reference.tv_sec - mt_Timeout.tv_sec) > time_out)) {
			fError.TreatError(1, 0, "Time out with no event");
			break;
		}
		if (fStatus != ACQ_NOCURRCTRLBUF)
			break;
	};
	if (fBuffer)
		fBuffer->SetAttributs(true);
}

//_________________________________________________________________________________
void GNetClientFDT::ReadBuffer(GBuffer& _Buffer) {
	// Read a buffer ; it just calls the method 'GetEventBuffer' and copies it into the given buffer
	while (true) {
		GetBuffer(false);
		if (fStatus != ACQ_NOCURRCTRLBUF)
			break;
	};
	if (fBuffer) {
		fBuffer->Equal(_Buffer);
		fBuffer->SetAttributs();
	}
}
//_________________________________________________________________________________
void GNetClientFDT::SendFrame(MFMCommonFrame * frame) {
	int size= frame->GetFrameSize();

	if (size != 0)
		size = frame->GetFrameSize();
	SendBufferTransport((unsigned char*) frame->GetPointHeader(),size);
}
//_________________________________________________________________________________
void GNetClientFDT::WriteBuffer(GBuffer * buff) {
	int size= buff->GetBufSize();

	if (size == 0)
		size = buff->GetBufSizeFromBuffer();
	if (size == 0){
			fError.TreatError(1,0," GNetClientFDT::WriteBuffer buffer size is null");
			return;
	}
	if (buff->GetBufDataChar()!=NULL){
	SendBufferTransport((unsigned char*)(buff->GetBufDataChar()),size);

	}else{
		fError.TreatError(1,0," GNetClientFDT::WriteBuffer buffer pointer is null");
					return;
	}
}
//_________________________________________________________________________________
bool GNetClientFDT::SendBufferTransport(unsigned char* buff, int size) {

	int err = fTransmitter->send(buff, size);
	if (err == OK) {

		err = fTransmitter->sendDISCONNECT();
	}
	if (err != OK) {
		cout << "transmission error " << err << endl;
	}
	return true;
}
