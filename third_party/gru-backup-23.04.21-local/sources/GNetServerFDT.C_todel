void GNetServerFDT::ReadBuffer() {
	// Read a buffer
	TString tempos = "GRU_OK";
	struct timeval mt_reference;
	struct timeval mt_Timeout;
	struct timezone tz;
	gettimeofday(&mt_Timeout, &tz);
	gettimeofday(&mt_reference, &tz);
	int time_out = 400;

	fStatus = ACQ_OK;
	while (true) {
		//bool test=ReceiveConnections();
		ReceiveConnections();
		if (GetBufferTransport(false)) break;

		gettimeofday(&mt_Timeout, &tz);

		if (((mt_reference.tv_sec - mt_Timeout.tv_sec) > time_out)) {
			fError.TreatError(1, 0, "Time out with no event");
			break;
		}

	};
	if (fBuffer)
		fBuffer->SetAttributs(true);

}

//_________________________________________________________________________________________
void GNetServerFDT::WaitCommandsFromClient() {

	// Wait till we get the start message
	// If the message is in few words, all words must be separate by a space ' '
	// not threaded waiting command

	GNetServerFDT* iGNet = this;

	fError.TreatError(0, 0, "Spectra Server is running");
	iGNet->SetRunningFlag(true);
	while (GetRunningFlag()) {

		// Check if there is a message waiting on one of the sockets.
		// Wait not longer than 20 ms (returns -1 in case of time-out).

		iGNet->TreatmentCommands();

	}// end of if((s =fMon->Select(20)!=(TSocket*)-1)
	usleep(100);
	//  if (gROOT->IsInterrupted())break;
}// end of while(1)

//_________________________________________________________________________________________
void GNetServerFDT::ErrorMessage(int err, const char * message) {
	TString tempos;
	switch (err) {
	case R_TCP_SOCKET:
		tempos.Form("%s (R_TCP_SOCKET)", message);
		break;
	case R_TCP_BIND:
		tempos.Form("%s (R_TCP_BIND)", message);
		break;
	case R_TCP_LISTEN:
		tempos.Form("%s (R_TCP_LISTEN)", message);
		break;
	default:
		tempos.Form("%s (UNKNOWN)", message);
	}

	fError.TreatError(2, err, tempos);
}
