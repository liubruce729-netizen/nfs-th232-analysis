//_________________________________________________________________________________________
bool GNetServerFDT::ReceiveConnections() {

	bool ret = false;

	if ((fReceiver->getConnectionSocket()) <= 0) {
		// accept new connection from client
		int err = fReceiver->connect();
		if (err != OK)
			ErrorMessage(err, "ReceiveConnections");
		cout << "debug ReceiveConnections = "<<fReceiver->getConnectionSocket()<<"\n";
		ret = false;

	}

	return ret;
}
//_________________________________________________________________________________________
long long GNetServerFDT::DecodMFMsize(unsigned char* buf) {

	long long nbytes = 0x8000;

	if (buf[0] & 0x80)
		nbytes = (int) buf[1] + ((int) buf[2] << 8) + ((int) buf[3] << 16); // little endian
	else
		nbytes = (int) buf[3] + ((int) buf[2] << 8) + ((int) buf[1] << 16); // big endian
	nbytes = nbytes << (buf[0] & 0xf);
	return nbytes;
}

//_________________________________________________________________________________________
bool GNetServerFDT::GetBufferTransport(bool afficher) {
	// Get  Transport Buffer
	// return true if data ok

	TString tempos;
	//	fStatus = ACQ_OK;
	cout
			<< "-----------------------------------GetBufferTransport-------------\n";

	RazZone();

	int err = fReceiver->receive(fMFMpt->GetPointHeader(), 4);

	if (err != OK) {
		fError.TreatError(2, err, "GetBufferTransport: Reception error");
		return false;
	}

	unsigned int Cmd = *((unsigned int *) fMFMpt->GetPointHeader());
	if (Cmd == FDT_HELLO) {
		fError.TreatError(1, err, "GetBufferTransport: Hello");
		return true;
	}

	if (Cmd == FDT_DISCONNECT) {
		// disconnect
		return false;
	}

	long long nbytes =
			DecodMFMsize((unsigned char*) (fMFMpt->GetPointHeader()));

	cout << "debug  reception of " << nbytes << "bytes\n";
	cout << "debug GetFrameSize" << fMFMpt->GetFrameSize()
			<< "\n";
	if (nbytes > fMFMpt->GetFrameSize()) {
		fMFMpt->SetBufferSize(nbytes);
	}

	err
			= fReceiver->receive(((char*) fMFMpt->GetPointHeader()) + 4, nbytes
					- 4);
	fMFMpt->SetAttributs();
	fMFMpt->HeaderDisplay();
	fMFMpt->DumpRaw(48, 0);

	fBuffer->SetExternalDataZone(fMFMpt->GetPointHeader(),
			fMFMpt->GetFrameSize());

	return true;
}

