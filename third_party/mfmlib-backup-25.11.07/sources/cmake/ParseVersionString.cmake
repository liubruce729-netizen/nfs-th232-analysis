string(REGEX REPLACE "([0-9]+)[.][0-9]+[.][0-9]+" "\\1" MFM_MAJOR_VERSION ${MFM_VERSION_STRING})
string(REGEX REPLACE "[0-9]+[.]([0-9]+)[.][0-9]+" "\\1" MFM_MINOR_VERSION ${MFM_VERSION_STRING})
string(REGEX REPLACE "[0-9]+[.][0-9]+[.]([0-9]+)" "\\1" MFM_PATCH_VERSION ${MFM_VERSION_STRING})
set(MFM_VERSION ${MFM_MAJOR_VERSION}.${MFM_MINOR_VERSION}.${MFM_PATCH_VERSION})
